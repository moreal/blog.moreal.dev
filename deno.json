{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "nodeModulesDir": "auto",
  "permissions": {
    "script": {
      "read": ["."],
      "env": ["NAPI_RS_NATIVE_LIBRARY_PATH", "NAPI_RS_FORCE_WASI"],
      "net": {
        "allow": ["127.0.0.1:8080"]
      },
      "ffi": [
        "./node_modules/.deno/@seonbi+node@0.2.2/node_modules/@seonbi/node/seonbi.darwin-arm64.node",
        "./node_modules/.deno/@seonbi+node@0.2.2/node_modules/@seonbi/node/seonbi.linux-x64-gnu.node",
        "./node_modules/.deno/@seonbi+node@0.2.2/node_modules/@seonbi/node/seonbi.linux-x64-musl.node"
      ],
      "write": {
        "allow": ["public_html"]
      }
    }
  },
  "imports": {
    "seonbi": "npm:@seonbi/node@^0.2.2",
    "jikji": "jsr:@hongminhee/jikji@^0.4.0",
    "@std/yaml": "jsr:@std/yaml",
    "@std/cli": "jsr:@std/cli",
    "@std/log": "jsr:@std/log",
    "@std/http": "jsr:@std/http",
    "@std/path": "jsr:@std/path"
  },
  "tasks": {
    "dev": "deno run -P=script main.ts --serve --watch"
  }
}
