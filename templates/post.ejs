<!DOCTYPE html>
<html lang="ko">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>
    <%= title %> — <%= site.title %>
  </title>
  <link rel="stylesheet" href="/static/style.css">
  <link rel="shortcut icon" href="/static/logo.svg" type="image/svg+xml">
  <meta name="description" content="<%= metadata?.description || '블로그 포스트' %>">
  <meta name="og:title" content="<%= title %> — <%= site.title %>">
  <meta name="author" content="Moreal (Lee Dogeon)" />
  <meta name="fediverse:creator" content="moreal@hackers.pub" />
  <link rel="me" href="https://social.silicon.moe/@moreal" />
  <link rel="me" href="https://hackers.pub/@moreal" />
</head>

<body class="post">
  <header class="post-header">
    <a href="/" class="back-link">다른 글 보기</a>
    <% if (typeof multiViews !== 'undefined' && multiViews) {
        const langNames = {
          'ko-Hang': '한국어',
          'ko-Kore': '國漢文',
          'en': 'English',
        };
        const views = [...multiViews].filter(([key]) => key != null);
        if (views.length > 1) { %>
        <nav class="lang-nav">
        <% for (const [key, href] of views) {
            const lang = key.language?.toString();
            const label = langNames[lang] || lang;
            const current = typeof viewKey !== 'undefined' && viewKey === key;
        %>
            <% if (current) { %>
            <span class="lang-current"><%= label %></span>
            <% } else { %>
            <a href="<%= href %>"><%= label %></a>
            <% } %>
        <% } %>
        </nav>
    <% } } %>

  <% if (published) { %>
    <time datetime="<%= published.toISOString() %>" class="publish-date">
      <%= published.getFullYear() %>년 <%= published.getMonth() + 1 %>월 <%= published.getDate() %>일
    </time>
  <% } %>
  </header>

  <main>
    <article>
      <%- body %>
    </article>
  </main>
</body>

</html>
